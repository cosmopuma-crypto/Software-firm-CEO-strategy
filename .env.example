# ---- E-Mail-Versand der Website-Formulare ----
# Ohne gesetzte Variablen läuft alles im Log-Fallback (E-Mail erscheint nur in der Konsole).
# So bauen und laufen Build/Dev auch ohne Secrets.

# Empfänger aller Formular-Anfragen (Default, falls leer: info@st-haustechnik.de)
CONTACT_TO_EMAIL=info@st-haustechnik.de

# Verifizierte Absenderadresse (für Resend/SMTP erforderlich)
CONTACT_FROM_EMAIL=website@st-haustechnik.de

# Option A: Resend (empfohlen). Ist RESEND_API_KEY gesetzt, wird Resend genutzt.
RESEND_API_KEY=

# Option B: SMTP (nur falls SMTP_HOST gesetzt und kein RESEND_API_KEY vorhanden).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ---- Heizreport REST API v2 (Wärmepumpen-Check / Förderrechner) ----
# Ohne HEIZREPORT_API_KEY bleibt die API-Anbindung inaktiv; die eingebetteten
# Widgets funktionieren unabhängig davon weiter.

# API-Key aus dem Heizreport-Account (Einstellungen -> API-Schnittstelle).
# Wird als "Authorization: Bearer <key>" gesendet. Format z. B.: hr_live_...
HEIZREPORT_API_KEY=

# Bearer-Token, mit dem Heizreport ausgehende Webhooks signiert. Im Account
# unter "Webhook Auth" als Bearer-Token hinterlegen; hier denselben Wert setzen.
#   Webhook-Adresse: https://<domain>/api/heizreport/webhook
HEIZREPORT_WEBHOOK_SECRET=

# Optional: abweichende Base URL (Default: https://heizreport.net/api/v2).
HEIZREPORT_API_URL=

# ---- Lead-Log (Anfragen-Tracking) ----
# Ohne gesetzte Variablen läuft das Lead-Log im Konsolen-Fallback.
# Tabellen-Setup und Auswertungs-Queries: siehe docs/tracking.md

# Projekt-URL aus dem Supabase-Dashboard (https://<projekt>.supabase.co)
SUPABASE_URL=

# Service-Role-Key (Settings -> API). Nur serverseitig verwenden, nie im Client!
SUPABASE_SERVICE_ROLE_KEY=

# ---- News-Ticker ----
# Optional: RSS-Feed-URL(s) für den Ticker (kommagetrennt für mehrere).
# Ohne Angabe wird ein Google-News-Suchfeed zu Wärmepumpe/Förderung genutzt.
# Für einen reinen Fachpresse-Feed hier die verifizierte Feed-URL eintragen.
# Fällt bei Nichterreichbarkeit auf die kuratierten Meldungen (src/data/news.json) zurück.
NEWS_RSS_URL=
